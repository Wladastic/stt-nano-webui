# Copy this file to .env for local Docker Compose runs.

# Ports
STT_BACKEND_PORT=8882
STT_FRONTEND_PORT=7861

# GPU selection
CUDA_VISIBLE_DEVICES=0

# Backend runtime
MODEL_TTL_SECONDS=300
UPLOAD_DIR=/tmp/stt-uploads

# Frontend dev/preview proxy target. The production Docker frontend uses nginx.
API_URL=http://localhost:8882
